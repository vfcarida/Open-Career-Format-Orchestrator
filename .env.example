# =============================================================================
# Agent Knowledge Compiler and Control Plane — Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your local environment.
# Never commit the .env file — it is listed in .gitignore.

# ---------------------------------------------------------------------------
# OKF Bundle
# ---------------------------------------------------------------------------
# Path to the OKF knowledge bundle directory (defaults to ./.okf)
AKCP_BUNDLE_PATH=./sample-data/.okf

# ---------------------------------------------------------------------------
# LLM Provider (optional — for local inference via Ollama/Gemma)
# ---------------------------------------------------------------------------
# Set to "ollama" to route MCP tool inference to a local Ollama instance.
# When unset or set to another value, the tailor_resume tool returns
# structured context for the host LLM to process.
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=gemma4:e4b

# ---------------------------------------------------------------------------
# Automation Runtime Mode
# ---------------------------------------------------------------------------
# Controls how browser automation tools operate:
#   sandbox                  — (default) uses local HTML fixtures only
#   recorded-fixture         — replays recorded browser sessions
#   explicit-authorized-live — enables live browser automation (requires HITL approval)
AUTOMATION_RUNTIME_MODE=sandbox

# ---------------------------------------------------------------------------
# OpenTelemetry (optional)
# ---------------------------------------------------------------------------
# Set to "true" to enable OpenTelemetry tracing and metrics collection.
OTEL_ENABLED=false

# ---------------------------------------------------------------------------
# Legacy Compatibility
# ---------------------------------------------------------------------------
# Set to "true" ONLY if you need the deprecated @akcp/mcp-server to execute
# real browser side effects. This is NOT recommended — use
# @akcp/mcp-automation-server instead.
AKCP_LEGACY_ALLOW_SIDE_EFFECTS=false
