# AKCP Environment Variables Configuration
# Copy this file to .env and configure for your local environment

# ==========================================
# Control Plane Settings
# ==========================================
# Enable or disable strict Human-In-The-Loop approvals for side-effect tools
AKCP_REQUIRE_HITL=true

# Dashboard port for the Control Plane
AKCP_DASHBOARD_PORT=3000

# ==========================================
# MCP Server Settings
# ==========================================
# The path to the compiled Knowledge IR json
AKCP_IR_PATH=dist/knowledge-ir.json

# The path to the bundle directory
AKCP_BUNDLE_PATH=./

# ==========================================
# LLM Providers (for Evals and Agents)
# ==========================================
# OpenAI API Key (required for evals and openwiki generation)
OPENAI_API_KEY=

# Anthropic API Key (optional)
ANTHROPIC_API_KEY=

# ==========================================
# Source Connectors (Optional)
# ==========================================
# Confluence connection for knowledge ingestion
CONFLUENCE_DOMAIN=
CONFLUENCE_USER=
CONFLUENCE_API_TOKEN=

# Notion integration token
NOTION_TOKEN=
