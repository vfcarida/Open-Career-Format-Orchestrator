{
  "name": "@akcp/cli",
  "version": "0.1.0",
  "description": "AKCP CLI: Generate, validate, update, and publish akcp context packs.",
  "type": "module",
  "bin": {
    "akcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch",
    "clean": "node -e \"fs.rmSync('dist', {recursive:true,force:true}); fs.rmSync('*.tsbuildinfo', {force:true})\"",
    "test": "vitest run"
  },
  "dependencies": {
    "@akcp/core": "workspace:*",
    "@akcp/conformance": "workspace:*",
    "@akcp/evals": "workspace:*",
    "commander": "^12.1.0",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vfcarida/Agent-Knowledge-Compiler-and-Control-Plane.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/vfcarida/Agent-Knowledge-Compiler-and-Control-Plane#readme",
  "bugs": {
    "url": "https://github.com/vfcarida/Agent-Knowledge-Compiler-and-Control-Plane/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "ai-agents",
    "knowledge-management",
    "mcp",
    "governance",
    "compilation"
  ]
}
