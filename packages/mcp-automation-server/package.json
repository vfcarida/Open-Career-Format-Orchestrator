{
  "name": "@akcp/mcp-automation-server",
  "version": "0.1.0",
  "private": true,
  "description": "AKCP MCP Automation Server. Executes policy-governed, human-in-the-loop workflows across domains.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "clean": "node -e \"fs.rmSync('dist', {recursive:true,force:true}); fs.rmSync('*.tsbuildinfo', {force:true})\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "catalog:",
    "@akcp/core": "workspace:*",
    "better-sqlite3": "^12.11.1",
    "ioredis": "^5.11.1",
    "playwright": "^1.49.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "catalog:",
    "tsx": "^4.19.0",
    "typescript": "catalog:"
  }
}
