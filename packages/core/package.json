{
  "name": "@akcp/core",
  "version": "0.1.0",
  "description": "Agent Knowledge Compiler and Control Plane (AKCP) Core Engine. Handles bundle parsing, schema validation, and profile compliance.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./dist/cli/validate-bundle.js": "./dist/cli/validate-bundle.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "clean": "node -e \"fs.rmSync('dist', {recursive:true,force:true}); fs.rmSync('*.tsbuildinfo', {force:true})\""
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.78.0",
    "@opentelemetry/exporter-metrics-otlp-grpc": "^0.220.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.220.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "gray-matter": "^4.0.3",
    "yaml": "^2.9.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vfcarida/Agent-Knowledge-Compiler-and-Control-Plane.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/vfcarida/Agent-Knowledge-Compiler-and-Control-Plane#readme",
  "bugs": {
    "url": "https://github.com/vfcarida/Agent-Knowledge-Compiler-and-Control-Plane/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "ai-agents",
    "knowledge-management",
    "mcp",
    "governance",
    "compilation"
  ]
}
