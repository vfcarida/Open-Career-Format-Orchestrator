{
  "name": "@akcp/mcp-profile-server",
  "version": "0.1.0",
  "private": true,
  "description": "AKCP MCP Profile Server. Exposes normalized knowledge artifacts and schemas via MCP tools and resources.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "clean": "node -e \"fs.rmSync('dist', {recursive:true,force:true}); fs.rmSync('*.tsbuildinfo', {force:true})\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "catalog:",
    "zod": "catalog:",
    "@akcp/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "@types/node": "catalog:",
    "tsx": "^4.19.0"
  }
}
