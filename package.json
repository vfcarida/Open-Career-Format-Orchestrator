{
  "name": "agent-ready-knowledge-reference-architecture",
  "version": "0.1.0",
  "private": true,
  "description": "Enterprise-grade reference architecture for building agent-ready knowledge bases using Open Knowledge Format (OKF) and Model Context Protocol (MCP).",
  "author": "Vinicius Carida",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "test:watch": "pnpm -r run test:watch",
    "test:unit": "pnpm -r run test:unit",
    "test:integration": "pnpm -r run test:integration",
    "test:contract": "vitest run packages/mcp-profile-server packages/mcp-automation-server",
    "test:e2e": "pnpm --filter @ocf/dashboard exec playwright test",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm -r run clean",
    "validate:bundle": "tsx packages/core/src/cli/validate-bundle.ts",
    "migrate:bundle": "tsx packages/core/src/cli/migrate-bundle.ts",
    "evals": "pnpm --filter @ocf/evals run evals",
    "dev:profile-server": "pnpm --filter @ocf/mcp-profile-server dev",
    "dev:automation-server": "pnpm --filter @ocf/mcp-automation-server dev",
    "dev:dashboard": "pnpm --filter @ocf/dashboard dev"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "@types/node": "^22.0.0",
    "vitest": "^3.2.0",
    "prettier": "^3.5.0"
  }
}
